# Copie este ficheiro para ".env" para testar localmente com "netlify dev".
# Em produção, estas variáveis configuram-se em:
#   Netlify → Site settings → Environment variables

# Credenciais do administrador inicial (criado automaticamente no
# primeiro pedido à API, apenas se ainda não existir nenhum utilizador).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=defina-uma-password-forte-aqui
ADMIN_EMAIL=

# Netlify Blobs é normalmente provisionado automaticamente pelo Netlify
# em sites com Netlify Functions, sem precisar de mais nada. Se receber
# o erro "The environment has not been configured to use Netlify
# Blobs", defina estas duas variáveis (ver README.md, secção
# "Resolver erro de Netlify Blobs"):
NETLIFY_SITE_ID=
NETLIFY_BLOBS_TOKEN=
